<Window
    x:Class="MailGrabber.Views.SettingsWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:MailGrabber.ViewModels"
    Title="Settings"
    Width="560"
    x:DataType="vm:SettingsDialogViewModel"
    WindowStartupLocation="CenterOwner"
    mc:Ignorable="d">
    <Grid
        Margin="22"
        RowDefinitions="Auto,*,Auto"
        RowSpacing="18">
        <StackPanel Spacing="3">
            <TextBlock Classes="settingsHeader" Text="Analysis Settings" />
            <TextBlock Classes="settingsSubHeader" Text="Provider, Limits und Export in einem Blick." />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="0,8" Spacing="14">

                <!-- Config File -->
                <Border
                    Classes="card settingsSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="settingsSectionTitle" Text="Config File" />
                        <Grid ColumnDefinitions="120,*" ColumnSpacing="10">
                            <TextBlock Classes="settingsLabel" VerticalAlignment="Center" Text="Config Path:" />
                            <TextBox Grid.Column="1" Text="{Binding ConfigPath}" Watermark="appsettings.json" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Providers -->
                <Border
                    Classes="card settingsSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="settingsSectionTitle" Text="Providers" />
                        <CheckBox Content="Enable Outlook" IsChecked="{Binding EnableOutlook}" />
                        <CheckBox Content="Enable Gmail" IsChecked="{Binding EnableGmail}" />
                    </StackPanel>
                </Border>

                <!-- Newsletter Clustering -->
                <Border
                    Classes="card settingsSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="settingsSectionTitle" Text="Newsletter Clustering" />
                        <CheckBox Content="Cluster newsletters separately" IsChecked="{Binding EnableNewsletterClustering}" />
                    </StackPanel>
                </Border>

                <!-- Message Limits -->
                <Border
                    Classes="card settingsSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="settingsSectionTitle" Text="Message Limits" />
                        <Grid ColumnDefinitions="180,*" ColumnSpacing="10">
                            <TextBlock Classes="settingsLabel" VerticalAlignment="Center" Text="Max Messages:" />
                            <NumericUpDown
                                Grid.Column="1"
                                Maximum="999999"
                                Minimum="1"
                                Value="{Binding MaxMessages}" />
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Output Paths -->
                <Border
                    Classes="card settingsSection">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="settingsSectionTitle" Text="Output Paths" />
                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Classes="settingsLabel" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="CSV Output:" />
                            <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OutputPath}" Watermark="output/sender-clusters.csv" />
                            <TextBlock Classes="settingsLabel" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="JSON Output:" />
                            <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding JsonOutputPath}" Watermark="output/sender-clusters.json" />
                            <TextBlock Classes="settingsLabel" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="HTML Viewer:" />
                            <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding HtmlOutputPath}" Watermark="output/cluster-viewer.html" />
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- Footer buttons -->
        <StackPanel
            Grid.Row="2"
            HorizontalAlignment="Right"
            Orientation="Horizontal"
            Spacing="10"
            Margin="0,4,0,0">
            <Button
                x:Name="SaveAsButton"
                MinWidth="100"
                Content="Save As..." />
            <Button
                MinWidth="100"
                Command="{Binding CancelCommand}"
                Content="Cancel" />
            <Button
                MinWidth="100"
                Command="{Binding OkCommand}"
                Content="OK" />
        </StackPanel>
    </Grid>
</Window>
