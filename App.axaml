<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MailGrabber.App"
             RequestedThemeVariant="Default">
  <Application.Styles>
    <FluentTheme />

    <Style Selector="Window:light">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0" Color="#FFF7F1E8" />
          <GradientStop Offset="1" Color="#FFEAF3F4" />
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="Window:dark">
      <Setter Property="Background">
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
          <GradientStop Offset="0" Color="#FF242B34" />
          <GradientStop Offset="1" Color="#FF2E3743" />
        </LinearGradientBrush>
      </Setter>
    </Style>

    <Style Selector="TextBlock.headline:light">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FF2D3A3A" />
    </Style>

    <Style Selector="TextBlock.headline:dark">
      <Setter Property="FontSize" Value="24" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FFE4E9EE" />
    </Style>

    <Style Selector="Border.card:light">
      <Setter Property="Background" Value="#F8FFFFFF" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="BorderBrush" Value="#33A0A0A0" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.card:dark">
      <Setter Property="Background" Value="#18FFFFFF" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="14" />
      <Setter Property="BorderBrush" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Border.senderRow:light">
      <Setter Property="Background" Value="#1FFFFFFF" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="Border.senderRow:dark">
      <Setter Property="Background" Value="#12FFFFFF" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>

    <Style Selector="TextBlock.settingsHeader:light">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FF2C3940" />
    </Style>

    <Style Selector="TextBlock.settingsHeader:dark">
      <Setter Property="FontSize" Value="20" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#FFE2E8ED" />
    </Style>

    <Style Selector="TextBlock.settingsSubHeader">
      <Setter Property="Opacity" Value="0.78" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style Selector="TextBlock.settingsSectionTitle">
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style Selector="TextBlock.settingsLabel">
      <Setter Property="Opacity" Value="0.88" />
    </Style>

    <Style Selector="Border.card.settingsSection">
      <Setter Property="Padding" Value="16" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.18" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.card.settingsSection:pointerover:light">
      <Setter Property="Background" Value="#FCFFFFFF" />
      <Setter Property="BorderBrush" Value="#40A0A0A0" />
    </Style>

    <Style Selector="Border.card.settingsSection:pointerover:dark">
      <Setter Property="Background" Value="#20FFFFFF" />
      <Setter Property="BorderBrush" Value="#24FFFFFF" />
    </Style>
  </Application.Styles>
</Application>
